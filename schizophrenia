def plot_fig1(ctrl_mat, schz_mat):
    fig, axes = plt.subplots(1, 2, figsize=(12, 5))
    vmax = max(np.abs(ctrl_mat).max(), np.abs(schz_mat).max())
    for ax, mat, tag, title in zip(
            axes, [ctrl_mat, schz_mat], ['(a)', '(b)'], ['Healthy', 'Diseased']):
        im = ax.imshow(np.abs(mat), cmap='hot', vmin=0, vmax=vmax,
                        interpolation='nearest', aspect='auto')
        ax.set_title(f'{tag} {title}', fontsize=11)
        ax.set_xlabel('Nodes', fontsize=9)
        ax.set_ylabel('Nodes', fontsize=9)
        plt.colorbar(im, ax=ax, label='Connectivity Strength', shrink=0.85)
    fig.suptitle('Fig. 1 — Dataset 1: Functional Connectomes (83 ROIs)',
                  fontsize=11, fontweight='bold')
    plt.tight_layout()
    fig.savefig('fig1_connectomes.png', dpi=180, bbox_inches='tight')
    plt.close(fig)
    print("  Saved: fig1_connectomes.png")


