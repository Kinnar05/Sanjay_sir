PERCENTAGES = [0.5, 1.0, 2.0, 5.0, 10.0, 25.0, 50.0, 60.0, 70.0, 80.0]

# 20 shuffles × 5 folds = λ = 100 feature signatures  (paper Sec. IV.A)
N_SHUFFLES   = 20
N_FOLDS      = 5
N_JOBS       = -1
RANDOM_STATE = 42

# Plot style matching paper Fig 3 (blue circle solid / red square dashed / green triangle dash-dot)
STYLE = {
    'LASSO':  dict(color='#1f77b4', marker='o', ls='-',  lw=1.8, ms=5, label='LASSO'),
