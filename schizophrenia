}


# ═══════════════════════════════════════════════════════════════════════
# 1.  DATA LOADING
# ═══════════════════════════════════════════════════════════════════════

def load_connectomes(file_path, resolution_idx=0):
    """
    Load one parcellation resolution.
    The (5,1) object array holds 5 RESOLUTIONS (not CV folds):
      index 0 → 83 ROIs  ← Dataset 1 (paper)
    Returns X (54,p), y (54,), one ctrl matrix, one schz matrix, n_rois.
    """
    expected = RESOLUTION_ROIS[resolution_idx]
    with h5py.File(file_path, 'r') as f:
        ctrl_col = f['SC_FC_Connectomes/FC_correlation/ctrl']
        schz_col = f['SC_FC_Connectomes/FC_correlation/schz']
        ctrl_mat = f[ctrl_col[resolution_idx, 0]][:]   # (27, ROI, ROI)
        schz_mat = f[schz_col[resolution_idx, 0]][:]

    assert ctrl_mat.shape[1] == expected
    n_rois = ctrl_mat.shape[1]
    tri    = np.triu_indices(n_rois, k=1)

    def vec(mats):
        return np.abs(np.array([mats[i][tri] for i in range(len(mats))],
                                dtype=np.float64))

    X = np.vstack([vec(ctrl_mat), vec(schz_mat)])
    y = np.array([0]*len(ctrl_mat) + [1]*len(schz_mat), dtype=np.int32)
    print(f"  Res {resolution_idx}: {n_rois} ROIs | p={X.shape[1]} | "
          f"ctrl={int((y==0).sum())}, schz={int((y==1).sum())}")
    return X, y, ctrl_mat[0], schz_mat[0], n_rois


# ═══════════════════════════════════════════════════════════════════════
# 2.  FEATURE RANKERS
# ═══════════════════════════════════════════════════════════════════════

def rank_lasso(Xs, y):
    """
    Rank by LASSO regularisation PATH ENTRY ORDER.
    Features entering at highest alpha (strongest shrinkage) are the
    most discriminative and enter consistently → positive KI.
    Tie-break for never-entering features: |coef| at densest alpha.
    """
    y_f = y.astype(np.float64)
    alphas, coefs, _ = lasso_path(Xs, y_f, n_alphas=100,
                                   max_iter=3000, eps=1e-4)
    p_loc       = coefs.shape[0]
    entry_alpha = np.zeros(p_loc)
    for j in range(p_loc):
        nz = np.where(coefs[j] != 0)[0]
        if len(nz):
            entry_alpha[j] = alphas[nz[0]]
    final_coef = np.abs(coefs[:, -1])
    return np.lexsort((final_coef, entry_alpha))[::-1].copy()


def rank_relief(Xs, y):
    """ReliefF vectorised over all n subjects (paper eq. 3-5)."""
    n, p = Xs.shape
    X0   = Xs[y == 0]
    X1   = Xs[y == 1]
    w    = np.zeros(p)
    for i in range(n):
        xl          = Xs[i]
        same, other = (X0, X1) if y[i] == 0 else (X1, X0)
        d_same  = np.einsum('ij,ij->i', same  - xl, same  - xl)
        d_other = np.einsum('ij,ij->i', other - xl, other - xl)
        si = d_same.argmin()
        if d_same[si] < 1e-12:
            d_same[si] = np.inf
        hit  = same [d_same .argmin()]
        miss = other[d_other.argmin()]
        w   += (xl - miss) ** 2 - (xl - hit) ** 2
    return np.argsort(w / n)[::-1].copy()


def rank_anova(Xs, y):
    """One-way ANOVA F-statistic (paper eq. 6-7)."""
    F, _ = f_classif(Xs, y)
    F    = np.nan_to_num(F, nan=0.0, posinf=0.0, neginf=0.0)
    return np.argsort(F)[::-1].copy()


RANKERS = {'LASSO': rank_lasso, 'Relief': rank_relief, 'ANOVA': rank_anova}


# ═══════════════════════════════════════════════════════════════════════
# 3.  STABILITY METRICS  (paper eq. 8-11)
# ═══════════════════════════════════════════════════════════════════════

def compute_ki_ji(signatures, p):
    """
    signatures : list of 1-D int arrays, all length k
    p          : total feature count
    """
    lam = len(signatures)
    if lam < 2:
        return 1.0, 1.0
    k = len(signatures[0])
    if k == 0:
        return 1.0, 1.0

    S = np.zeros((lam, p), dtype=np.int32)
    for i, sig in enumerate(signatures):
        S[i, sig] = 1

    intersect = (S @ S.T).astype(np.float64)
    iu = np.triu_indices(lam, k=1)
    r  = intersect[iu]

    # Kuncheva (eq. 8-9)
    k2p   = float(k) ** 2 / float(p)
    denom = float(k) - k2p
    ki    = float(np.mean((r - k2p) / denom)) if abs(denom) > 1e-12 else 1.0

    # Jaccard (eq. 10-11)
    union = 2.0 * float(k) - r
    ji    = float(np.mean(np.where(union > 0, r / union, 1.0)))

    return ki, ji


# ═══════════════════════════════════════════════════════════════════════
# 4.  ONE SHUFFLE  (parallelised)
# ═══════════════════════════════════════════════════════════════════════

def _one_shuffle(shuffle_id, X, y, percentages):
    """
    5-fold CV.  Per fold: scale once, rank once per method,
    slice top-k for every pct — no re-fitting.
    Collects: acc, f1, recall, precision, and feature signatures.
    """
    p   = X.shape[1]
    ks  = [max(1, int(pct / 100.0 * p)) for pct in percentages]
    skf = StratifiedKFold(n_splits=N_FOLDS, shuffle=True,
                           random_state=RANDOM_STATE + shuffle_id)

    acc_s = {m: np.zeros(len(percentages)) for m in RANKERS}
    f1_s  = {m: np.zeros(len(percentages)) for m in RANKERS}
    rec_s = {m: np.zeros(len(percentages)) for m in RANKERS}
    pre_s = {m: np.zeros(len(percentages)) for m in RANKERS}
    sigs  = {m: [[] for _ in percentages]  for m in RANKERS}

    for tr_idx, te_idx in skf.split(X, y):
        X_tr, X_te = X[tr_idx], X[te_idx]
        y_tr, y_te = y[tr_idx], y[te_idx]

        sc    = StandardScaler()
        Xtr_s = sc.fit_transform(X_tr)
        Xte_s = sc.transform(X_te)

        for mname, ranker in RANKERS.items():
            rank = ranker(Xtr_s, y_tr)          # full ranking, length p

            for pi, k in enumerate(ks):
                sel  = rank[:k]                 # free slice

                clf = LogisticRegression(C=1.0, max_iter=500,
                                          solver='lbfgs',
                                          random_state=RANDOM_STATE)
                clf.fit(Xtr_s[:, sel], y_tr)
                pred = clf.predict(Xte_s[:, sel])

                acc_s[mname][pi] += accuracy_score(y_te, pred)
                f1_s [mname][pi] += f1_score(y_te, pred, zero_division=0)
                rec_s[mname][pi] += recall_score(y_te, pred, zero_division=0)
                pre_s[mname][pi] += precision_score(y_te, pred, zero_division=0)
                sigs [mname][pi].append(sel.copy())

    result = {}
    for mname in RANKERS:
        result[mname] = {
            'acc':  acc_s[mname] / N_FOLDS,
            'f1':   f1_s [mname] / N_FOLDS,
            'rec':  rec_s[mname] / N_FOLDS,
            'pre':  pre_s[mname] / N_FOLDS,
            'sigs': sigs [mname],
        }
    return result


# ═══════════════════════════════════════════════════════════════════════
# 5.  FULL EVALUATION
# ═══════════════════════════════════════════════════════════════════════

def evaluate(X, y, percentages):
    p = X.shape[1]
    print(f"  {N_SHUFFLES} shuffles × {N_FOLDS} folds = "
          f"{N_SHUFFLES*N_FOLDS} signatures | n_jobs={N_JOBS}")

    t0 = time.time()
    shuffles = Parallel(n_jobs=N_JOBS, verbose=2, backend='loky')(
        delayed(_one_shuffle)(s, X, y, percentages)
        for s in range(N_SHUFFLES)
    )
    print(f"  ✓ Parallel CV done in {time.time()-t0:.1f}s")

    # collect λ=100 signatures
    all_sigs = {m: [[] for _ in percentages] for m in RANKERS}
    for sr in shuffles:
        for mname in RANKERS:
            for pi in range(len(percentages)):
                all_sigs[mname][pi].extend(sr[mname]['sigs'][pi])

    # aggregate
    t1 = time.time()
    results = {m: {'acc': [], 'f1': [], 'rec': [], 'pre': [],
                   'ki':  [], 'ji': []}
               for m in RANKERS}

    for mname in RANKERS:
        for pi in range(len(percentages)):
            acc_v = [sr[mname]['acc'][pi] for sr in shuffles]
            f1_v  = [sr[mname]['f1'] [pi] for sr in shuffles]
            rec_v = [sr[mname]['rec'][pi] for sr in shuffles]
            pre_v = [sr[mname]['pre'][pi] for sr in shuffles]
            ki, ji = compute_ki_ji(all_sigs[mname][pi], p)

            results[mname]['acc'].append(float(np.mean(acc_v)))
            results[mname]['f1'] .append(float(np.mean(f1_v)))
            results[mname]['rec'].append(float(np.mean(rec_v)))
            results[mname]['pre'].append(float(np.mean(pre_v)))
            results[mname]['ki'] .append(ki)
            results[mname]['ji'] .append(ji)

    print(f"  ✓ Stability metrics done in {time.time()-t1:.1f}s")
    return results, all_sigs


