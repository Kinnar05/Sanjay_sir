# 8.  FIGURE 5
# ═══════════════════════════════════════════════════════════════════════

def roi_frequency(all_sigs, percentages, n_rois, pct_subset=None):
    tri     = np.triu_indices(n_rois, k=1)
    freq    = {m: np.zeros(n_rois, dtype=np.int64) for m in RANKERS}
    use_set = set(pct_subset) if pct_subset else set(percentages)
    for pi, pct in enumerate(percentages):
        if pct not in use_set:
            continue
        for mname in RANKERS:
            for sig in all_sigs[mname][pi]:
                np.add.at(freq[mname], tri[0][sig], 1)
                np.add.at(freq[mname], tri[1][sig], 1)
    return freq


def _roi_names():
    lh = ['bankssts','caud-ant-cing','caud-mid-front','cuneus','entorhinal',
          'fusiform','inf-parietal','inf-temporal','isthmus-cing','lat-occipital',
          'lat-orbitofrontal','lingual','med-orbitofrontal','mid-temporal',
          'parahippocampal','paracentral','pars-opercularis','pars-orbitalis',
          'pars-triangularis','pericalcarine','postcentral','post-cingulate',
          'precentral','precuneus','rost-ant-cing','rost-mid-front',
          'sup-frontal','sup-parietal','sup-temporal','supramarginal',
          'frontal-pole','temporal-pole','transverse-temporal','insula',
          'thalamus','caudate','putamen','pallidum','brain-stem',
          'hippocampus','amygdala']
    rh    = [r+'-rh' for r in lh]
    names = lh + rh + ['accumbens']
    assert len(names) == 83
    return names


def plot_fig5(freq_dict):
    roi_names = _roi_names()
    hs        = 41
    methods   = list(RANKERS.keys())
    fig, axes = plt.subplots(2, 3, figsize=(18, 11))
    fig.suptitle('Fig. 5 — Affected Brain Regions (Top 10 per Hemisphere)',
                  fontsize=12, fontweight='bold')
    for col, method in enumerate(methods):
        freq = freq_dict[method]
        for row, (start, end, hemi) in enumerate([
                (0,  hs,             'Left Hemisphere'),
                (hs, len(roi_names), 'Right Hemisphere')]):
            ax     = axes[row, col]
            hf     = freq[start:end].astype(float)
            hn     = roi_names[start:end]
            top    = np.argsort(hf)[::-1][:10]
            tnames = [hn[i] for i in top]
            tvals  = [hf[i] for i in top]
            ax.barh(range(10), tvals[::-1],
                    color='steelblue', edgecolor='#003060', alpha=0.8)
            ax.set_yticks(range(10))
            ax.set_yticklabels(tnames[::-1], fontsize=7)
            ax.set_xlabel('Selection Frequency', fontsize=8)
            ax.set_title(f'{method} — {hemi}', fontsize=9, fontweight='bold')
            ax.grid(axis='x', alpha=0.25)
            ax.spines[['top', 'right']].set_visible(False)
    plt.tight_layout(rect=[0, 0, 1, 0.96])
    fig.savefig('fig5_roi_frequencies.png', dpi=180, bbox_inches='tight')
    plt.close(fig)
    print("  Saved: fig5_roi_frequencies.png")


