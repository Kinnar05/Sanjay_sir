def main():
    bar     = '═' * 62
    t_start = time.time()

    print(bar)
    print('  Dataset 1 — University of Lausanne  (83 ROIs, n=54)')
    print(bar)

    X, y, ctrl_ex, schz_ex, n_rois = load_connectomes(
        FILE_PATH, resolution_idx=RESOLUTION_IDX)

    print('\n[Fig 1]  Plotting example connectomes ...')
    plot_fig1(ctrl_ex, schz_ex)

    print(f'\n[Fig 3]  Evaluating  '
          f'({N_SHUFFLES} shuffles × {N_FOLDS} folds = '
          f'{N_SHUFFLES * N_FOLDS} signatures per method per pct)')
    t_eval = time.time()
    results, all_sigs = evaluate(X, y, PERCENTAGES)
    print(f"  ✓ Total evaluation: {time.time()-t_eval:.1f}s")

    print('\n[Fig 3]  Plotting 2×2 figure (a) Acc  (b) F1  (c) KI  (d) JI ...')
    plot_fig3(results, PERCENTAGES)

    print('\n[Tables II & III]  Accuracy | Precision | Recall | F1-Score')
    print_tables(results, PERCENTAGES)

    print('\n[Fig 5]  ROI frequencies (reusing signatures — no extra work) ...')
    freq = roi_frequency(all_sigs, PERCENTAGES, n_rois,
                          pct_subset=[0.5, 1.0, 2.0, 5.0, 10.0, 25.0, 50.0])
    plot_fig5(freq)

    print(f'\n{bar}')
    print(f'  All figures saved.  Total runtime: {time.time()-t_start:.1f}s')
    print(bar)


if __name__ == '__main__':
    main()
